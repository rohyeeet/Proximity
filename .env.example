# --- Database ---
# Any standard PostgreSQL connection string works (Neon, Vercel Postgres, Supabase, RDS, ...).
# Local dev and `prisma migrate dev` both read this.
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# --- Auth.js (NextAuth v5) ---
# Generate one with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET="replace-with-a-random-32-byte-secret"

# --- Seed script ---
# Shared password hashed for every seeded demo user. Change it, or override per-environment.
# SEED_DEMO_PASSWORD="demo1234"
