// Prisma schema for Proximity — mirrors the TS interfaces in src/types/*.ts field-for-field so the
// API layer's response shapes don't have to change from what every Studio component already expects.
//
// JSONB is used deliberately (not a shortcut) for nested structures that are always read/written as
// one unit and never queried field-by-field in SQL: form field definitions (with their validations/
// visibility rules/lookup sources), flow node/edge graphs, and submission answer/evidence/version
// records. Everything that's ever filtered, joined, or counted in SQL is a real column.

generator client {
  provider      = "prisma-client-js"
  // "native" covers local dev (macOS/Windows/whatever you're on); "debian-openssl-3.0.x" covers
  // the node:20-bookworm-slim base image used by the Cloud Run Dockerfile. Vercel's build
  // environment is handled automatically by Vercel's own Prisma integration.
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Domain configuration ----------

model DomainPack {
  id                        String   @id
  slug                      String   @unique
  name                      String
  version                   String
  status                    String // "draft" | "published" | "retired"
  description               String
  chainOfCustodyModes       String[] // ChainOfCustodyMode[]
  defaultChainOfCustodyMode String?

  organizations Organization[]
  stages        Stage[]
  formTemplates FormTemplate[]
}

model Organization {
  id           String   @id
  name         String
  slug         String   @unique
  domainPackId String
  planTier     String // "starter" | "growth" | "enterprise"
  status       String // "active" | "suspended" | "trial"
  createdAt    DateTime

  domainPack        DomainPack         @relation(fields: [domainPackId], references: [id])
  roles             Role[]
  memberships       OrgMembership[]
  connectors        Connector[]
  projects          Project[]
  paymentAgreements PaymentAgreement[]

  @@index([domainPackId])
}

// A real-world site/deal an organization runs — e.g. one specific biochar facility and its
// offtake deal. An organization can run several projects. Each project gets its own Flow (the
// process graph) and its own Payments (milestone templates, agreements, escrow) — but Stages and
// FormTemplates stay domain-pack-scoped (shared question/methodology library every project on
// that domain pack draws from), since the underlying MRV questions are standardized by the
// domain pack's methodology, not project-specific.
model Project {
  id             String   @id
  organizationId String
  domainPackId   String // inherited from the organization at creation time
  name           String
  description    String?
  status         String // "active" | "archived"
  createdAt      DateTime @default(now())

  organization        Organization                @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  flowTemplates       FlowTemplate[]
  submissions         Submission[]
  paymentAgreements   PaymentAgreement[]
  milestoneTemplates  MilestoneTemplate[]
  serviceIntegrations ProjectServiceIntegration[]

  @@index([organizationId])
  @@index([domainPackId])
}

// ---------- Identity & access ----------

model User {
  id              String  @id
  fullName        String
  email           String  @unique
  passwordHash    String
  avatarInitials  String
  status          String // "active" | "invited" | "disabled"
  // Platform tier is cross-org and intentionally NOT modeled as an OrgMembership (a platform
  // admin isn't "a member" of any one org) — matches src/types/identity.ts's CurrentSession.isPlatformAdmin.
  isPlatformAdmin Boolean @default(false)
  // Onboarding profile details, captured when a Team & Access admin invites someone.
  mobileNumber    String?
  country         String?
  state           String?
  district        String?

  memberships                  OrgMembership[]
  submissions                  Submission[]                @relation("SubmittedBy")
  notifications                Notification[]
  paymentAgreementParties      PaymentAgreementParty[]
  requestedServiceIntegrations ProjectServiceIntegration[]
}

model Role {
  id             String   @id
  organizationId String? // null for platform-tier roles (e.g. Super Admin)
  name           String
  tier           String // RoleTier
  description    String
  canView        String[]
  canAct         String[]
  cannot         String[]

  organization Organization?   @relation(fields: [organizationId], references: [id])
  memberships  OrgMembership[]

  @@index([organizationId])
}

model OrgMembership {
  id             String @id
  organizationId String
  userId         String
  roleId         String
  status         String // "active" | "invited" | "removed"

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role         Role         @relation(fields: [roleId], references: [id])

  @@unique([organizationId, userId])
  @@index([userId])
}

// ---------- Process model: Stage -> FormTemplate, and the Flow generated from both ----------

model Stage {
  id           String  @id
  domainPackId String
  name         String
  description  String?
  sortOrder    Int

  // Flat id lists, matching src/types/stages.ts exactly — resolved against Connector/FormTemplate
  // in application code (the same pattern StageBoardClient.tsx already uses), not enforced as SQL
  // foreign keys. A Stage owns this membership list; FormTemplate does not carry a back-reference,
  // mirroring the one-directional TS model instead of inventing a second source of truth.
  connectorIds    String[]
  formTemplateIds String[]

  domainPack DomainPack @relation(fields: [domainPackId], references: [id])

  @@index([domainPackId])
}

model FormTemplate {
  id           String @id
  domainPackId String
  code         String
  name         String
  description  String
  category     String

  domainPack  DomainPack            @relation(fields: [domainPackId], references: [id])
  versions    FormTemplateVersion[]
  submissions Submission[]

  @@unique([domainPackId, code])
  @@index([domainPackId])
}

model FormTemplateVersion {
  id             String    @id @default(cuid())
  formTemplateId String
  versionNo      Int
  // "draft" (actively edited, mutable) | "published" (immutable history — never mutated again once set).
  // A form has at most one draft row at a time; every published row is permanent history, which is
  // what lets old submissions keep rendering against the exact fields they were submitted under.
  status         String    @default("draft")
  publishedAt    DateTime?
  fields         Json // FormFieldDefinition[] — validations, visibility rules, lookup sources, link filters, all nested

  formTemplate FormTemplate @relation(fields: [formTemplateId], references: [id], onDelete: Cascade)

  @@unique([formTemplateId, versionNo])
}

model FlowTemplate {
  id           String @id
  projectId    String
  code         String
  name         String
  status       String // "draft" | "published"
  versionNo    Int
  triggerLabel String
  nodes        Json // FlowNodeDefinition[] (sourceStageId tags backbone nodes owned by the sync engine)
  edges        Json // FlowEdgeDefinition[] (auto tags edges owned by the sync engine)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, code])
  @@index([projectId])
}

// ---------- Records ----------

model Submission {
  id                    String   @id
  displayId             String
  formTemplateId        String
  // Which project's flow this was collected under — nullable since a form can in principle be
  // filled out before any project links to it, and legacy rows predate this column existing.
  // Lets Records/Overview attribute a record to one project when an org runs several.
  projectId             String?
  formTemplateVersionNo Int
  flowNodeLabel         String
  reviewStatus          String
  syncStatus            String
  submittedByUserId     String
  currentVersionNo      Int
  updatedAt             DateTime
  answers               Json // SubmissionAnswer[]
  evidence              Json // EvidenceFile[]
  versions              Json // SubmissionVersionRecord[]
  reviewActions         Json // ReviewActionRecord[]
  linkedSubmissionIds   String[]
  smartCheckSummary     String
  // Sample submissions made from the Form Builder's Preview panel to test a form before
  // publishing — excluded from Records lists and FormTemplate submission counts by default.
  isTest                Boolean  @default(false)

  formTemplate FormTemplate @relation(fields: [formTemplateId], references: [id], onDelete: Cascade)
  submittedBy  User         @relation("SubmittedBy", fields: [submittedByUserId], references: [id])
  project      Project?     @relation(fields: [projectId], references: [id])

  @@index([formTemplateId])
  @@index([submittedByUserId])
  @@index([reviewStatus])
  @@index([projectId])
}

// ---------- Connectors & devices ----------

model Connector {
  id             String  @id
  organizationId String
  name           String
  connectorType  String
  protocol       String?
  status         String
  endpoint       String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  devices      Device[]

  @@index([organizationId])
}

model Device {
  id             String @id
  connectorId    String
  name           String
  externalRef    String
  calibration    Json? // DeviceCalibration
  coveragePct    Int
  lastGapMinutes Int?
  tags           Json // TelemetryTag[]

  connector Connector         @relation(fields: [connectorId], references: [id], onDelete: Cascade)
  telemetry TelemetryStream[]

  @@index([connectorId])
}

model TelemetryStream {
  id            String @id @default(cuid())
  deviceId      String
  parameterCode String
  unit          String
  latestValue   Float
  thresholdHigh Float?
  points        Json // TelemetryPoint[]

  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@unique([deviceId, parameterCode])
}

// ---------- Notifications ----------

model Notification {
  id             String    @id @default(cuid())
  userId         String
  type           String // "form_published" | "claim_needs_consent" | "payout_blocked_on_bav" | "milestone_confirmed_by_registry" | ...
  title          String
  body           String
  formTemplateId String?
  // Generic destination for any notification type added after formTemplateId — avoids adding a
  // new nullable FK column per new notifiable entity (claims, agreements, payouts, ...).
  linkUrl        String?
  createdAt      DateTime  @default(now())
  readAt         DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ---------- Payments ("Proximity Pay") ----------
//
// Milestone-gated offtake agreements: a buyer/project agreement (PaymentAgreement) has a milestone
// schedule; a ground partner files a MilestoneClaim with EvidenceAttachments per milestone; it
// becomes payable once every required StakeholderConsent is approved; PayoutInstructions (one per
// revenue-split participant) then clear a KYC/BAV dual gate before Proximity Pay (simulated, see
// src/lib/proximity-pay.ts) settles them. All "who did this" fields are plain userId scalars
// resolved via the existing getUser() lookup, matching how Submission.submittedByUserId /
// ReviewActionRecord.reviewerUserId are already resolved elsewhere — not Prisma relations, to avoid
// relation-name churn on User for what are display-only references.

model PaymentAgreement {
  id                       String   @id
  organizationId           String
  // The real project this deal funds — added alongside the pre-existing free-text projectName
  // (kept as a display fallback for agreements predating this column, never re-derived from it).
  projectId                String
  buyerName                String
  projectName              String
  currency                 String
  totalValue               Float
  pricePerCredit           Float?
  escrowInterestAllocation String // "buyer" | "pool" | "platform"
  fxRateTimingPolicy       String // "lock_at_consent" | "apply_at_execution"
  status                   String // "draft" | "active" | "completed"
  createdByUserId          String
  createdAt                DateTime @default(now())

  organization Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  splitRules   SplitRule[]
  milestones   Milestone[]
  parties      PaymentAgreementParty[]
  recipients   PayoutRecipient[]
  escrow       EscrowAccount?
  auditEntries PaymentAuditLogEntry[]

  @@index([organizationId])
  @@index([projectId])
}

// A reusable milestone definition, authored once per project in the Payments section — the one
// lever a project developer configures (what % of the total this milestone releases, and how
// that release splits across platform/developer/farmer_community/investor). A flow's payment_step
// node references one of these by id; a real PaymentAgreement's Milestone/SplitRule rows are
// snapshotted from the selected templates at agreement-creation time (same principle as
// FormTemplateVersion snapshotting fields — a later template edit must never retroactively change
// a signed agreement's terms).
model MilestoneTemplate {
  id                 String @id
  projectId          String
  type               String // "setup_capex" | "achievement" | "monitoring_cycle"
  label              String
  percentOfTotal     Float
  verificationSource String
  order              Int

  project    Project                  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  splitRules MilestoneTemplateSplit[]

  @@index([projectId])
}

model MilestoneTemplateSplit {
  id                  String @id
  milestoneTemplateId String
  participantRole     String // "platform" | "developer" | "farmer_community" | "investor"
  percent             Float

  milestoneTemplate MilestoneTemplate @relation(fields: [milestoneTemplateId], references: [id], onDelete: Cascade)

  @@index([milestoneTemplateId])
}

model SplitRule {
  id                 String  @id
  paymentAgreementId String
  // Null = agreement-wide split (the original model, still how pre-template agreements work).
  // Set = this milestone's own split, snapshotted from its MilestoneTemplate's splits — lets
  // different milestones on the same agreement pay different roles different percentages, e.g. a
  // capex milestone paying 100% to the developer vs. a production milestone splitting four ways.
  milestoneId        String?
  participantRole    String // "platform" | "developer" | "farmer_community" | "investor"
  percent            Float

  paymentAgreement PaymentAgreement @relation(fields: [paymentAgreementId], references: [id], onDelete: Cascade)
  milestone        Milestone?       @relation(fields: [milestoneId], references: [id], onDelete: Cascade)

  @@index([paymentAgreementId])
  @@index([milestoneId])
}

model Milestone {
  id                 String  @id
  paymentAgreementId String
  // Which MilestoneTemplate this was snapshotted from, if any — powers the live ledger rollup
  // (getMilestoneLedger) that a flow's payment_step node shows. Null for agreements created before
  // templates existed, or a milestone hand-added without picking a template.
  sourceTemplateId   String?
  type               String // "setup_capex" | "achievement" | "monitoring_cycle"
  label              String
  percentOfTotal     Float
  verificationSource String
  registryRef        String?
  order              Int
  status             String // "not_due" | "claim_submitted" | "consented" | "paid"

  paymentAgreement   PaymentAgreement    @relation(fields: [paymentAgreementId], references: [id], onDelete: Cascade)
  claims             MilestoneClaim[]
  payoutInstructions PayoutInstruction[]
  splitRules         SplitRule[]

  @@index([paymentAgreementId])
  @@index([sourceTemplateId])
}

model MilestoneClaim {
  id                String   @id
  milestoneId       String
  submittedByUserId String
  submittedAt       DateTime @default(now())
  claimedAmount     Float
  status            String // "submitted" | "consented" | "rejected" | "paid"

  milestone          Milestone            @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  evidence           EvidenceAttachment[]
  consents           StakeholderConsent[]
  payoutInstructions PayoutInstruction[]

  @@index([milestoneId])
}

model EvidenceAttachment {
  id          String   @id
  claimId     String
  sourceType  String // "dmrv_export" | "site_inspection_photo" | "production_log" | "registry_document" | "other"
  fileRef     String
  fileName    String
  hash        String
  submittedAt DateTime @default(now())

  claim MilestoneClaim @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@index([claimId])
}

model StakeholderConsent {
  id                String    @id
  claimId           String
  requiredRole      String // "investor" | "platform_ops" | "registry"
  consentedByUserId String?
  consentedAt       DateTime?
  status            String // "pending" | "approved" | "rejected"
  rejectionReason   String?

  claim MilestoneClaim @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@index([claimId])
}

// Cross-org, resource-scoped access grant for investor/registry parties — deliberately NOT an
// OrgMembership, since these personas need visibility into a specific agreement regardless of
// (and independent from) any org-staff membership. See src/lib/authz.ts's requirePaymentPartyAccess.
model PaymentAgreementParty {
  id                 String @id
  paymentAgreementId String
  userId             String
  role               String // "investor" | "registry"
  investedAmount     Float?

  paymentAgreement PaymentAgreement @relation(fields: [paymentAgreementId], references: [id], onDelete: Cascade)
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([paymentAgreementId, userId, role])
  @@index([userId])
}

model PayoutRecipient {
  id                 String    @id
  paymentAgreementId String
  role               String // "developer" | "farmer_community"
  name               String
  kycStatus          String // "not_started" | "in_review" | "approved" | "rejected" | "re_verification_required"
  bavStatus          String
  kycVerifiedAt      DateTime?
  bavVerifiedAt      DateTime?

  paymentAgreement   PaymentAgreement    @relation(fields: [paymentAgreementId], references: [id], onDelete: Cascade)
  payoutInstructions PayoutInstruction[]

  @@index([paymentAgreementId])
}

model PayoutInstruction {
  id              String    @id
  milestoneId     String
  claimId         String
  recipientId     String?
  participantRole String // "platform" | "developer" | "farmer_community" | "investor"
  amount          Float
  currency        String
  status          String // "blocked_awaiting_verification" | "blocked_awaiting_kyc" | "blocked_awaiting_bav" | "ready" | "routed" | "paid"
  proximityPayRef String?
  paidAt          DateTime?

  milestone Milestone        @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  claim     MilestoneClaim   @relation(fields: [claimId], references: [id], onDelete: Cascade)
  recipient PayoutRecipient? @relation(fields: [recipientId], references: [id])
  overrides GateOverride[]

  @@index([milestoneId])
  @@index([claimId])
  @@index([recipientId])
}

model EscrowAccount {
  id                    String   @id
  paymentAgreementId    String   @unique
  heldAmount            Float
  currency              String
  corePortionBalance    Float
  interestAccruedToDate Float    @default(0)
  status                String // "holding" | "partially_released" | "fully_released"
  fundedAt              DateTime @default(now())

  paymentAgreement PaymentAgreement @relation(fields: [paymentAgreementId], references: [id], onDelete: Cascade)
}

model GateOverride {
  id                       String   @id
  payoutInstructionId      String
  overriddenGate           String // "kyc" | "bav" | "both"
  partnerApprovalByUserId  String?
  investorApprovalByUserId String?
  justification            String
  status                   String // "pending" | "granted" | "denied"
  createdAt                DateTime @default(now())

  payoutInstruction PayoutInstruction @relation(fields: [payoutInstructionId], references: [id], onDelete: Cascade)

  @@index([payoutInstructionId])
}

model PaymentAuditLogEntry {
  id                 String   @id
  paymentAgreementId String
  eventType          String
  payload            Json
  timestamp          DateTime @default(now())
  previousHash       String
  hash               String

  paymentAgreement PaymentAgreement @relation(fields: [paymentAgreementId], references: [id], onDelete: Cascade)

  @@index([paymentAgreementId])
}

// ---------- Marketplace (Science & Data Integrations) ----------

/**
 * A real-world scientific/verification service a project can connect for a listed cost — soil
 * carbon modeling, remote sensing, lab analysis, LCA, and so on. Global catalog data (curated, not
 * per-org), same role as DomainPack: seeded once, referenced everywhere. Deliberately informational
 * — activation below is simulated, no real API call or billing happens (see README's Prototype
 * boundaries).
 */
model ServiceListing {
  id           String   @id
  category     String
  name         String
  provider     String
  description  String
  pricingModel String // "per_sample" | "per_hectare_month" | "subscription_month" | "per_api_call" | "custom_quote"
  priceLabel   String
  apiAvailable Boolean
  badges       String[]
  website      String?
  order        Int
  createdAt    DateTime @default(now())

  integrations ProjectServiceIntegration[]

  @@index([category])
}

/**
 * Which project has connected which service listing — the only mutable, project-scoped state in
 * the Marketplace. One row per (project, listing); toggling status doesn't delete history.
 */
model ProjectServiceIntegration {
  id                String   @id
  projectId         String
  serviceListingId  String
  status            String // "active" | "disconnected"
  requestedByUserId String
  activatedAt       DateTime @default(now())

  project        Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  serviceListing ServiceListing @relation(fields: [serviceListingId], references: [id], onDelete: Cascade)
  requestedBy    User           @relation(fields: [requestedByUserId], references: [id])

  @@unique([projectId, serviceListingId])
  @@index([projectId])
  @@index([serviceListingId])
}
